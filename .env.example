# =============================================================================
# Cigma Points — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored and must NEVER be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE — Neon PostgreSQL
# -----------------------------------------------------------------------------

# POOLED connection string (hostname contains "-pooler").
# Used at runtime by the PrismaNeon adapter for all application queries.
# Append ?connect_timeout=15 to handle Neon free-tier cold starts (scale to zero).
# Source: Neon Console → Project → Connection Details → Pooled connection
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.us-east-2.aws.neon.tech/DATABASE?sslmode=require&connect_timeout=15"

# UNPOOLED (direct) connection string (no "-pooler" in hostname).
# Used ONLY by prisma.config.ts for migrations (prisma migrate dev / prisma db push).
# Neon's pooler runs in transaction mode and does NOT support DDL — use direct URL here.
# Source: Neon Console → Project → Connection Details → Direct connection
DIRECT_URL="postgresql://USER:PASSWORD@HOST.us-east-2.aws.neon.tech/DATABASE?sslmode=require"

# -----------------------------------------------------------------------------
# AUTHENTICATION — NextAuth v5 (Auth.js)
# -----------------------------------------------------------------------------

# JWT signing secret. Generate with: openssl rand -base64 32
# Keep this value secret — it signs all session JWTs.
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"

# Base URL of the application. Use http://localhost:3000 for local dev.
# Change to your Vercel deployment URL in production.
NEXTAUTH_URL="http://localhost:3000"
